{
  "name": "@pe/database",
  "version": "0.0.0",
  "private": true,
  "description": "Supabase client factories and generated types for pe-platform",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./admin": "./src/admin.ts",
    "./middleware": "./src/middleware.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --project-id \"$PE_SUPABASE_PROJECT_ID\" > src/types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.1",
    "@supabase/supabase-js": "2.45.4"
  },
  "peerDependencies": {
    "next": "^14.0.0"
  },
  "devDependencies": {
    "@pe/config": "workspace:*",
    "next": "14.2.15",
    "typescript": "5.6.2"
  }
}
